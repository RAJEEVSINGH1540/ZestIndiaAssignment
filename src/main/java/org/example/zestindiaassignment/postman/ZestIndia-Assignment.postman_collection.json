        {
          "name": "05 - Login as ADMIN (Save Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Token received', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data.token).to.not.be.empty;",
                  "    pm.expect(json.data.tokenType).to.eql('Bearer');",
                  "    // Save token to collection variable automatically",
                  "    pm.collectionVariables.set('adminToken', json.data.token);",
                  "    console.log('Admin Token saved: ' + json.data.token);",
                  "});",
                  "",
                  "pm.test('Role is ADMIN', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data.role).to.eql('ADMIN');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"usernameOrEmail\": \"adminuser\",\n    \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as ADMIN. Token is automatically saved to {{adminToken}} variable."
