    {
      "name": "AUTH MODULE",
      "description": "User Registration and Login endpoints - No JWT required",
      "item": [
        {
          "name": "01 - Register ADMIN User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has userId', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data.userId).to.not.be.empty;",
                  "    pm.expect(json.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Role is ADMIN', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data.role).to.eql('ADMIN');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"adminuser\",\n    \"email\": \"admin@zestindia.com\",\n    \"password\": \"admin123\",\n    \"fullName\": \"Admin User\",\n    \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new ADMIN user. No JWT token required."
          },
          "response": [
            {
              "name": "Success - 201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n    \"success\": true,\n    \"message\": \"User registered successfully\",\n    \"data\": {\n        \"userId\": \"USR2025-0042\",\n        \"username\": \"adminuser\",\n        \"email\": \"admin@zestindia.com\",\n        \"fullName\": \"Admin User\",\n        \"role\": \"ADMIN\"\n    },\n    \"timestamp\": \"2025-01-15T10:30:00\"\n}"
            }
          ]
        },
