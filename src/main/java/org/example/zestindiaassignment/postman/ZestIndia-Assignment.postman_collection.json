          "name": "09 - Create Employee 1 (Engineering)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Employee ID generated', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data.empId).to.not.be.empty;",
                  "    pm.expect(json.data.empId).to.include('EMP');",
                  "    // Save empId for later tests",
                  "    pm.collectionVariables.set('empId', json.data.empId);",
                  "    console.log('Employee ID: ' + json.data.empId);",
                  "});",
                  "",
                  "pm.test('Status is ACTIVE by default', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data.status).to.eql('ACTIVE');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
